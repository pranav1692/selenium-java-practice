<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="EAEmployeeSuite">
    <parameter name="url" value="http://eaapp.somee.com/"/>
    <parameter name="username" value="admin"/>
    <parameter name="password" value="password"></parameter>
    <parameter name="browser" value="chrome"/>

    <test name="LoginTests">
        <parameter name="signInPageTitle" value="Sign In — EA Employee App"></parameter>
        <classes>
            <class name="tests.LoginPageTest"/>
        </classes>
    </test>

    <test name="EmployeeTests">
        <parameter name="employeePageTitle" value="Employee List - EAEmployee"></parameter>
        <parameter name="empname" value="Sarah Johnson"></parameter>
        <parameter name="partialempname" value="Sarah"></parameter>
        <classes>
            <class name="tests.EmployeeListPageTest"/>
        </classes>
    </test>

    <test name = "CreateNewEmployeeTest">
        <parameter name="createNewEmployeePageTitle" value="Create Employee - EAEmployee"></parameter>
        <classes>
            <class name="tests.CreateNewEmployeeTest"/>
        </classes>
    </test>
</suite>

